<clickhouse>
  <storage_configuration>
    <disks>
      <s3_disk>
        <type>s3</type>
        <endpoint>http://minio:9000/ch-shared/mergetree/</endpoint>
        <access_key_id>writer</access_key_id>
        <secret_access_key>writer-secret</secret_access_key>
        <use_environment_credentials>false</use_environment_credentials>
      </s3_disk>
    </disks>
    <policies>
      <s3_main>
        <volumes>
          <main>
            <disk>s3_disk</disk>
          </main>
        </volumes>
      </s3_main>

      <hybrid_local_s3>
        <volumes>
          <hot>
            <disk>default</disk>
          </hot>
          <cold>
            <disk>s3_disk</disk>
          </cold>
        </volumes>
      </hybrid_local_s3>
    </policies>
  </storage_configuration>
</clickhouse>
